# =============================================================================
# AuraPost AI — Environment Variables Template (.env.example)
# Generated dynamically to match all process.env variables referenced in codebase.
# =============================================================================

# ---- APPLICATION CORE ----
NODE_ENV=production
PORT=3000
TEST_MODE=false

# ---- DATABASE CONFIGURATION ----
# For PostgreSQL connections:
# DATABASE_URL="postgresql://user:password@localhost:5432/aurapost"
# Or provide individual connection details:
SQL_HOST=""
SQL_USER=""
SQL_PASSWORD=""
SQL_DB_NAME=""
SQL_ADMIN_USER=""
SQL_ADMIN_PASSWORD=""

# Pool tuning settings:
PG_POOL_MAX=10
PG_POOL_IDLE_TIMEOUT_MS=30000
PG_POOL_CONN_TIMEOUT_MS=5000
PG_SSL=true

# ---- AUTHENTICATION AND SECURITY ----
# Key used to sign JWT Access Tokens. REQUIRED in production.
JWT_SECRET=""
# Key used to sign JWT Refresh Tokens. REQUIRED in production.
JWT_REFRESH_SECRET=""
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Symmetrical encryption key (AES-256-GCM) protecting social and Shopify OAuth tokens in the DB.
# MANDATORY: The server will refuse to start if this is unset or shorter than 16 characters!
ENCRYPTION_MASTER_KEY=""

# ---- PUBLIC URLS FOR OAUTH REDIRECTS ----
APP_URL=""
APP_BASE_URL=""

# ---- PAYMENT INTEGRATIONS (STYLING & BILLING) ----
# PayPal billing integration keys:
PAYPAL_CLIENT_ID=""
PAYPAL_CLIENT_SECRET=""
PAYPAL_ENV=sandbox
PAYPAL_WEBHOOK_ID=""

# Stripe billing integration keys:
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_STARTER_MONTHLY_PRICE_ID=""
STRIPE_STARTER_YEARLY_PRICE_ID=""
STRIPE_PRO_MONTHLY_PRICE_ID=""
STRIPE_PRO_YEARLY_PRICE_ID=""
STRIPE_ENTERPRISE_MONTHLY_PRICE_ID=""
STRIPE_ENTERPRISE_YEARLY_PRICE_ID=""

# ---- AI PROVIDERS & LLMS ----
GEMINI_API_KEY=""
GEMINI_IMAGES_API_KEY=""
GEMINI_MODEL=gemini-2.5-flash
OPENAI_API_KEY=""
OPENAI_IMAGES_API_KEY=""
OPENAI_MODEL=gpt-4o-mini
DEEPSEEK_API_KEY=""
DEEPSEEK_MODEL=deepseek-chat
CLAUDE_API_KEY=""

# ---- IMAGE GENERATION PROVIDERS ----
STABILITY_API_KEY=""
FLUX_API_KEY=""

# ---- VIDEO GENERATION PROVIDERS ----
VEO_API_KEY=""
RUNWAY_API_KEY=""
KLING_ACCESS_KEY=""
KLING_SECRET_KEY=""
PIKA_API_KEY=""
VIDEO_PROVIDER_LIVE=false

# ---- SHOPIFY PARTNERS INTEGRATION ----
SHOPIFY_API_KEY=""
SHOPIFY_API_SECRET=""
SHOPIFY_SYNC_TEST_MODE=false

# ---- META (FACEBOOK/INSTAGRAM) INTEGRATION ----
META_APP_ID=""
META_APP_SECRET=""
FB_LOGIN_CONFIG_ID=""
SOCIAL_PUBLISH_LIVE=false

# ---- EXTRACTION & DIAGNOSTICS ----
AURAPOST_ENABLE_TEST_DATASET=false

# ---- OBSERVABILITY & TRACKING ----
SENTRY_DSN=""
SENTRY_TRACES_SAMPLE_RATE=0.1
LOG_LEVEL=info
